<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Logs Spring normaux dans la console -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Logs Big Data dans un fichier séparé -->
    <appender name="BIG_DATA_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/app/logs/bigdata_events.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>/app/logs/bigdata_events-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxFileSize>128MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <!-- IMPORTANT : uniquement %msg%n pour avoir du JSON pur ligne par ligne -->
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- Logger dédié Big Data : écrit UNIQUEMENT dans le fichier, pas dans la console -->
    <logger name="BIG_DATA_LOGGER" level="INFO" additivity="false">
        <appender-ref ref="BIG_DATA_FILE"/>
    </logger>

    <!-- Tous les autres logs Spring → console uniquement -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>